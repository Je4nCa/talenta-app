VITE_BIBLIA_API_KEY=tu-api-key-de-biblia-com
VITE_EMAILJS_SERVICE_ID=tu-service-id-de-emailjs
VITE_EMAILJS_TEMPLATE_ID=tu-template-id-de-emailjs
VITE_EMAILJS_PUBLIC_KEY=tu-public-key-de-emailjs
# URL de la Cloud Function (pendiente de construir) que llama server-side a
# GetTokenSdk de TiloPay. Sin esta variable el módulo de Pagos muestra un
# estado "próximamente" en vez de intentar el checkout.
VITE_TILOPAY_TOKEN_ENDPOINT=https://tu-cloud-function.cloudfunctions.net/tilopayToken
